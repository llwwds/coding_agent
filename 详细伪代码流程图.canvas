{
	"nodes": [
		{"id": "main_group", "type": "group", "x": -400, "y": -100, "width": 1400, "height": 800, "label": "main.py - 入口文件"},
		{"id": "main_1", "type": "text", "text": "def main():\n    # 解析命令行参数（需求输入）\n    args = parse_args()\n    requirement = args.requirement", "x": -380, "y": -80, "width": 450, "height": 120},
		{"id": "main_2", "type": "text", "text": "    # 加载配置（从 config.py）\n    config = load_config()\n    # 初始化全局状态（从 state.py）\n    state = State(requirement=requirement)", "x": -380, "y": 60, "width": 450, "height": 140},
		{"id": "main_3", "type": "text", "text": "    # 初始化日志系统（从 logger.py）\n    logger = setup_logger(config.log_path)\n    logger.info(f'开始处理需求: {requirement}')", "x": -380, "y": 220, "width": 450, "height": 140},
		{"id": "main_4", "type": "text", "text": "    # 构建 LangChain Agent（从 agent.py）\n    agent = build_agent(config, state, logger)\n    # 启动主循环\n    agent.run()", "x": -380, "y": 380, "width": 450, "height": 140},
		{"id": "main_5", "type": "text", "text": "    # 输出最终结果\n    print(f'项目已交付至: {state.workspace_path}')\n    logger.info('流程结束')", "x": -380, "y": 540, "width": 450, "height": 100},
		
		{"id": "config_group", "type": "group", "x": 1100, "y": -100, "width": 1400, "height": 700, "label": "config.py - 配置管理"},
		{"id": "config_1", "type": "text", "text": "class Config:\n    # 从环境变量加载配置\n    def __init__(self):\n        load_dotenv()", "x": 1120, "y": -80, "width": 450, "height": 120},
		{"id": "config_2", "type": "text", "text": "        self.openai_api_key = os.getenv('OPENAI_API_KEY')\n        self.openai_base_url = os.getenv('OPENAI_BASE_URL')\n        self.model_name = os.getenv('MODEL_NAME', 'gpt-4')", "x": 1120, "y": 60, "width": 450, "height": 140},
		{"id": "config_3", "type": "text", "text": "        self.workspace_dir = os.getenv('WORKSPACE_DIR', './workspace')\n        self.max_fix_rounds = int(os.getenv('MAX_FIX_ROUNDS', 5))", "x": 1120, "y": 220, "width": 450, "height": 120},
		{"id": "config_4", "type": "text", "text": "        self.log_path = './logs'\n        # 确保目录存在\n        os.makedirs(self.workspace_dir, exist_ok=True)\n        os.makedirs(self.log_path, exist_ok=True)", "x": 1120, "y": 360, "width": 450, "height": 140},

		{"id": "state_group", "type": "group", "x": -400, "y": 800, "width": 1400, "height": 900, "label": "state.py - 全局状态管理"},
		{"id": "state_1", "type": "text", "text": "class State:\n    # 存储整个流程的状态数据\n    def __init__(self, requirement: str):\n        self.requirement = requirement  # 用户需求", "x": -380, "y": 820, "width": 450, "height": 140},
		{"id": "state_2", "type": "text", "text": "        self.task_template = {}  # 结构化任务模板\n        self.project_skeleton = {}  # 项目骨架结构\n        self.workspace_path = ''  # 生成代码的目标路径", "x": -380, "y": 980, "width": 450, "height": 140},
		{"id": "state_3", "type": "text", "text": "        self.fix_counter = 0  # 修复轮数计数器\n        self.current_phase = 'requirement'  # 当前阶段", "x": -380, "y": 1140, "width": 450, "height": 100},
		{"id": "state_4", "type": "text", "text": "        self.test_results = []  # 测试结果记录\n        self.failure_logs = []  # 失败日志（用于修复分析）", "x": -380, "y": 1260, "width": 450, "height": 100},
		{"id": "state_5", "type": "text", "text": "    def increment_fix_counter(self):\n        # 修复计数器递增\n        self.fix_counter += 1\n        return self.fix_counter", "x": -380, "y": 1380, "width": 450, "height": 120},
		{"id": "state_6", "type": "text", "text": "    def reset_fix_counter(self):\n        # 重置计数器（测试通过后）\n        self.fix_counter = 0", "x": -380, "y": 1520, "width": 450, "height": 100},

		{"id": "logger_group", "type": "group", "x": 1100, "y": 800, "width": 1400, "height": 700, "label": "logger.py - 日志系统"},
		{"id": "logger_1", "type": "text", "text": "def setup_logger(log_path: str):\n    # 创建日志记录器，记录到文件和控制台\n    logger = logging.getLogger('coding_agent')", "x": 1120, "y": 820, "width": 450, "height": 120},
		{"id": "logger_2", "type": "text", "text": "    # 文件 handler（记录所有日志）\n    file_handler = logging.FileHandler(f'{log_path}/agent.log')\n    file_handler.setLevel(logging.DEBUG)", "x": 1120, "y": 960, "width": 450, "height": 120},
		{"id": "logger_3", "type": "text", "text": "    # 控制台 handler（只显示 INFO 及以上）\n    console_handler = logging.StreamHandler()\n    console_handler.setLevel(logging.INFO)", "x": 1120, "y": 1100, "width": 450, "height": 120},
		{"id": "logger_4", "type": "text", "text": "    # 格式化器\n    formatter = logging.Formatter('[%(asctime)s] %(levelname)s: %(message)s')\n    file_handler.setFormatter(formatter)\n    console_handler.setFormatter(formatter)", "x": 1120, "y": 1240, "width": 450, "height": 140},
		{"id": "logger_5", "type": "text", "text": "    logger.addHandler(file_handler)\n    logger.addHandler(console_handler)\n    return logger", "x": 1120, "y": 1400, "width": 450, "height": 80},

		{"id": "tool_group", "type": "group", "x": -400, "y": 1800, "width": 1400, "height": 1000, "label": "tool.py - LangChain 工具集"},
		{"id": "tool_1", "type": "text", "text": "# 文件读写工具\n@tool\ndef read_file(file_path: str) -> str:\n    # 读取文件内容，供 LLM 分析\n    with open(file_path, 'r') as f:\n        return f.read()", "x": -380, "y": 1820, "width": 450, "height": 140},
		{"id": "tool_2", "type": "text", "text": "@tool\ndef write_file(file_path: str, content: str):\n    # 写入文件（创建或覆盖）\n    os.makedirs(os.path.dirname(file_path), exist_ok=True)\n    with open(file_path, 'w') as f:\n        f.write(content)", "x": -380, "y": 1980, "width": 450, "height": 160},
		{"id": "tool_3", "type": "text", "text": "# Shell 执行工具\n@tool\ndef run_shell(command: str) -> str:\n    # 执行 shell 命令，返回输出\n    result = subprocess.run(command, shell=True, capture_output=True, text=True)\n    return result.stdout + result.stderr", "x": -380, "y": 2160, "width": 450, "height": 160},
		{"id": "tool_4", "type": "text", "text": "# 代码检查工具\n@tool\ndef run_lint(file_path: str) -> str:\n    # 运行 ruff/black 格式化和 lint\n    result = run_shell(f'ruff check {file_path}')\n    return result", "x": -380, "y": 2340, "width": 450, "height": 140},
		{"id": "tool_5", "type": "text", "text": "@tool\ndef run_test(test_command: str) -> str:\n    # 运行测试命令（pytest/unittest）\n    result = run_shell(test_command)\n    return result", "x": -380, "y": 2500, "width": 450, "height": 120},
		{"id": "tool_6", "type": "text", "text": "@tool\ndef list_files(directory: str) -> list:\n    # 列出目录下所有文件\n    return os.listdir(directory)", "x": -380, "y": 2640, "width": 450, "height": 100},

		{"id": "prompts_group", "type": "group", "x": 1100, "y": 1800, "width": 1400, "height": 900, "label": "prompts.py - Prompt 模板"},
		{"id": "prompts_1", "type": "text", "text": "# 需求分析阶段 prompt\nREQUIREMENT_ANALYSIS_PROMPT = '''\n你是需求分析专家，分析用户需求：{requirement}\n识别需要明确的技术选型和功能边界。\n输出格式：JSON {\"unclear_points\": [...], \"tech_stack\": [...]}'''", "x": 1120, "y": 1820, "width": 450, "height": 180},
		{"id": "prompts_2", "type": "text", "text": "# 任务模板生成 prompt\nTASK_TEMPLATE_PROMPT = '''\n根据需求生成结构化任务模板：\n- 输入数据\n- 目标文件列表\n- 测试命令\n- 验收标准'''", "x": 1120, "y": 2020, "width": 450, "height": 160},
		{"id": "prompts_3", "type": "text", "text": "# 骨架设计 prompt\nSKELETON_DESIGN_PROMPT = '''\n设计项目骨架：\n- 目录结构\n- 配置文件\n- 入口文件\n- 测试目录\n输出 JSON 格式'''", "x": 1120, "y": 2200, "width": 450, "height": 180},
		{"id": "prompts_4", "type": "text", "text": "# 代码填充 prompt\nCODE_FILL_PROMPT = '''\n根据骨架填充代码，文件：{file_path}\n要求：\n- 简洁实现\n- 添加注释\n- 符合规范'''", "x": 1120, "y": 2400, "width": 450, "height": 160},
		{"id": "prompts_5", "type": "text", "text": "# 修复 prompt\nFIX_PROMPT = '''\n测试失败，错误信息：{error}\n失败类型：{failure_type}\n修复代码，只改必要部分'''", "x": 1120, "y": 2580, "width": 450, "height": 120},

		{"id": "agent_group", "type": "group", "x": -400, "y": 2900, "width": 1400, "height": 1100, "label": "agent.py - Agent 主循环"},
		{"id": "agent_1", "type": "text", "text": "def build_agent(config, state, logger):\n    # 构建 LangChain Agent\n    llm = ChatOpenAI(api_key=config.openai_api_key, base_url=config.openai_base_url, model=config.model_name)", "x": -380, "y": 2920, "width": 450, "height": 140},
		{"id": "agent_2", "type": "text", "text": "    # 加载工具集（从 tool.py）\n    tools = [read_file, write_file, run_shell, run_lint, run_test, list_files]", "x": -380, "y": 3080, "width": 450, "height": 100},
		{"id": "agent_3", "type": "text", "text": "    # 创建 Agent\n    agent = create_react_agent(llm=llm, tools=tools, prompt=get_system_prompt())\n    return AgentExecutor(agent=agent, tools=tools, state=state, logger=logger)", "x": -380, "y": 3200, "width": 450, "height": 140},
		{"id": "agent_4", "type": "text", "text": "class AgentExecutor:\n    def run(self):\n        # 主循环：依次执行各阶段\n        self.run_requirement_phase()\n        self.run_develop_phase()", "x": -380, "y": 3360, "width": 450, "height": 140},
		{"id": "agent_5", "type": "text", "text": "        self.run_test_phase()\n        # 测试失败会进入修复循环\n        self.run_deliver_phase()", "x": -380, "y": 3520, "width": 450, "height": 100},
		{"id": "agent_6", "type": "text", "text": "    def run_requirement_phase(self):\n        # 调用 phases/requirement.py\n        from phases.requirement import RequirementPhase\n        phase = RequirementPhase(self.agent, self.state, self.logger)\n        phase.execute()", "x": -380, "y": 3640, "width": 450, "height": 160},
		{"id": "agent_7", "type": "text", "text": "    # 其他阶段类似调用\n    # run_develop_phase() → phases/develop.py\n    # run_test_phase() → phases/test.py\n    # run_deliver_phase() → phases/deliver.py", "x": -380, "y": 3820, "width": 450, "height": 140},

		{"id": "req_group", "type": "group", "x": 1100, "y": 2900, "width": 1400, "height": 1200, "label": "phases/requirement.py - 需求分析阶段"},
		{"id": "req_1", "type": "text", "text": "class RequirementPhase:\n    def execute(self):\n        # 步骤1：LLM 分析需求，识别不明确点\n        unclear = self.analyze_requirement()", "x": 1120, "y": 2920, "width": 450, "height": 120},
		{"id": "req_2", "type": "text", "text": "    def analyze_requirement(self):\n        # 调用 LLM，使用 REQUIREMENT_ANALYSIS_PROMPT\n        response = self.agent.invoke(REQUIREMENT_ANALYSIS_PROMPT.format(requirement=self.state.requirement))\n        return json.loads(response)", "x": 1120, "y": 3060, "width": 450, "height": 160},
		{"id": "req_3", "type": "text", "text": "        # 步骤2：判断是否需要与用户交互\n        if unclear['unclear_points']:\n            self.interact_with_user(unclear)", "x": 1120, "y": 3240, "width": 450, "height": 100},
		{"id": "req_4", "type": "text", "text": "    def interact_with_user(self, unclear):\n        # 向用户提问，明确技术方案\n        for point in unclear['unclear_points']:\n            answer = input(f'请明确：{point}')\n            self.state.requirement += f'\\n{point}: {answer}'", "x": 1120, "y": 3360, "width": 450, "height": 160},
		{"id": "req_5", "type": "text", "text": "        # 步骤3：生成结构化任务模板\n        self.generate_task_template()", "x": 1120, "y": 3540, "width": 450, "height": 80},
		{"id": "req_6", "type": "text", "text": "    def generate_task_template(self):\n        # 调用 LLM，使用 TASK_TEMPLATE_PROMPT\n        response = self.agent.invoke(TASK_TEMPLATE_PROMPT.format(requirement=self.state.requirement))\n        self.state.task_template = json.loads(response)\n        self.logger.info(f'任务模板：{self.state.task_template}')", "x": 1120, "y": 3640, "width": 450, "height": 180},

		{"id": "dev_group", "type": "group", "x": -400, "y": 4100, "width": 1400, "height": 1000, "label": "phases/develop.py - 开发阶段"},
		{"id": "dev_1", "type": "text", "text": "class DevelopPhase:\n    def execute(self):\n        # 步骤1：确定项目骨架\n        self.design_skeleton()", "x": -380, "y": 4120, "width": 450, "height": 100},
		{"id": "dev_2", "type": "text", "text": "    def design_skeleton(self):\n        # 调用 LLM，使用 SKELETON_DESIGN_PROMPT\n        response = self.agent.invoke(SKELETON_DESIGN_PROMPT.format(task=self.state.task_template))\n        skeleton = json.loads(response)", "x": -380, "y": 4240, "width": 450, "height": 140},
		{"id": "dev_3", "type": "text", "text": "        # 创建目录和配置文件\n        for dir in skeleton['directories']:\n            os.makedirs(f'{self.state.workspace_path}/{dir}', exist_ok=True)\n        self.state.project_skeleton = skeleton", "x": -380, "y": 4400, "width": 450, "height": 140},
		{"id": "dev_4", "type": "text", "text": "        # 步骤2：单 agent 模式填充代码\n        self.fill_code()", "x": -380, "y": 4560, "width": 450, "height": 80},
		{"id": "dev_5", "type": "text", "text": "    def fill_code(self):\n        # 遍历骨架中的文件列表\n        for file_info in self.state.project_skeleton['files']:\n            file_path = file_info['path']", "x": -380, "y": 4660, "width": 450, "height": 120},
		{"id": "dev_6", "type": "text", "text": "            # 调用 LLM 生成代码\n            code = self.agent.invoke(CODE_FILL_PROMPT.format(file_path=file_path, spec=file_info['spec']))\n            # 使用 tool 写入文件\n            write_file(file_path, code)\n            self.logger.info(f'已生成：{file_path}')", "x": -380, "y": 4800, "width": 450, "height": 160},

		{"id": "test_group", "type": "group", "x": 1100, "y": 4100, "width": 1400, "height": 1100, "label": "phases/test.py - 测试阶段"},
		{"id": "test_1", "type": "text", "text": "class TestPhase:\n    def execute(self):\n        # 步骤1：创建测试环境\n        self.setup_test_env()", "x": 1120, "y": 4120, "width": 450, "height": 100},
		{"id": "test_2", "type": "text", "text": "    def setup_test_env(self):\n        # 安装依赖\n        run_shell('pip install -r requirements.txt')\n        self.logger.info('测试环境已配置')", "x": 1120, "y": 4240, "width": 450, "height": 120},
		{"id": "test_3", "type": "text", "text": "        # 步骤2：轻量化测试（lint + 格式化）\n        lint_pass = self.run_lint_tests()", "x": 1120, "y": 4380, "width": 450, "height": 80},
		{"id": "test_4", "type": "text", "text": "    def run_lint_tests(self):\n        # ruff/black 格式化\n        result = run_lint(self.state.workspace_path)\n        if 'error' in result:\n            self.handle_test_failure('lint', result)\n            return False\n        return True", "x": 1120, "y": 4480, "width": 450, "height": 180},
		{"id": "test_5", "type": "text", "text": "        # 步骤3：单元测试 + 集成测试 + 端到端测试\n        test_pass = self.run_all_tests()", "x": 1120, "y": 4680, "width": 450, "height": 80},
		{"id": "test_6", "type": "text", "text": "    def run_all_tests(self):\n        # 执行测试命令\n        result = run_test(self.state.task_template['test_command'])\n        if 'FAILED' in result or 'ERROR' in result:\n            self.handle_test_failure('unit_test', result)\n            return False\n        return True", "x": 1120, "y": 4780, "width": 450, "height": 180},
		{"id": "test_7", "type": "text", "text": "    def handle_test_failure(self, test_type, error):\n        # 记录失败信息，触发修复流程\n        self.state.failure_logs.append({'type': test_type, 'error': error})\n        self.logger.error(f'{test_type} 失败：{error}')\n        # 调用修复阶段\n        from phases.fix import FixPhase\n        FixPhase(self.agent, self.state, self.logger).execute()", "x": 1120, "y": 4980, "width": 450, "height": 200},

		{"id": "fix_group", "type": "group", "x": -400, "y": 5200, "width": 1400, "height": 1300, "label": "phases/fix.py - 修复阶段"},
		{"id": "fix_1", "type": "text", "text": "class FixPhase:\n    def execute(self):\n        # 步骤1：计数器递增\n        self.state.increment_fix_counter()\n        self.logger.info(f'修复轮数：{self.state.fix_counter}')", "x": -380, "y": 5220, "width": 450, "height": 140},
		{"id": "fix_2", "type": "text", "text": "        # 步骤2：判断是否超过阈值\n        if self.state.fix_counter > self.config.max_fix_rounds:\n            self.human_intervention()\n            return", "x": -380, "y": 5380, "width": 450, "height": 120},
		{"id": "fix_3", "type": "text", "text": "    def human_intervention(self):\n        # 超过阈值，人工介入\n        self.logger.warning('修复次数超限，需人工 review')\n        print('请手动检查代码并修复问题')\n        input('修复完成后按回车继续...')", "x": -380, "y": 5520, "width": 450, "height": 140},
		{"id": "fix_4", "type": "text", "text": "        # 步骤3：失败分析系统\n        failure_type = self.classify_failure()", "x": -380, "y": 5680, "width": 450, "height": 80},
		{"id": "fix_5", "type": "text", "text": "    def classify_failure(self):\n        # 分类失败类型\n        last_failure = self.state.failure_logs[-1]\n        error = last_failure['error']\n        # 简单规则分类\n        if 'import' in error: return 'missing_dependency'\n        if 'syntax' in error: return 'syntax_error'\n        if 'type' in error: return 'type_error'\n        return 'logic_error'", "x": -380, "y": 5780, "width": 450, "height": 200},
		{"id": "fix_6", "type": "text", "text": "        # 步骤4：根据失败类型选择修复策略\n        self.fix_bug(failure_type)", "x": -380, "y": 6000, "width": 450, "height": 80},
		{"id": "fix_7", "type": "text", "text": "    def fix_bug(self, failure_type):\n        # 调用 LLM 修复代码\n        error = self.state.failure_logs[-1]['error']\n        fix_code = self.agent.invoke(FIX_PROMPT.format(error=error, failure_type=failure_type))", "x": -380, "y": 6100, "width": 450, "height": 140},
		{"id": "fix_8", "type": "text", "text": "        # 应用修复（覆盖文件）\n        # fix_code 包含文件路径和修复后的代码\n        write_file(fix_code['file_path'], fix_code['content'])\n        self.logger.info(f'已修复：{fix_code[\"file_path\"]}')", "x": -380, "y": 6260, "width": 450, "height": 140},
		{"id": "fix_9", "type": "text", "text": "        # 步骤5：更新日志和文档\n        self.update_docs()", "x": -380, "y": 6420, "width": 450, "height": 60},
		{"id": "fix_10", "type": "text", "text": "        # 步骤6：回到测试阶段重新测试\n        from phases.test import TestPhase\n        TestPhase(self.agent, self.state, self.logger).execute()", "x": -380, "y": 6500, "width": 450, "height": 100},

		{"id": "deliver_group", "type": "group", "x": 1100, "y": 5200, "width": 1400, "height": 800, "label": "phases/deliver.py - 交付阶段"},
		{"id": "deliver_1", "type": "text", "text": "class DeliverPhase:\n    def execute(self):\n        # 步骤1：收集性能指标\n        metrics = self.collect_metrics()", "x": 1120, "y": 5220, "width": 450, "height": 100},
		{"id": "deliver_2", "type": "text", "text": "    def collect_metrics(self):\n        # 统计指标\n        return {\n            'fix_rounds': self.state.fix_counter,\n            'total_files': len(self.state.project_skeleton['files']),\n            'test_pass_rate': self.calculate_pass_rate()\n        }", "x": 1120, "y": 5340, "width": 450, "height": 180},
		{"id": "deliver_3", "type": "text", "text": "        # 步骤2：生成项目报告和文档\n        self.generate_report(metrics)", "x": 1120, "y": 5540, "width": 450, "height": 80},
		{"id": "deliver_4", "type": "text", "text": "    def generate_report(self, metrics):\n        # 生成 README.md 和项目文档\n        report = f'''# 项目报告\\n\\n修复轮数：{metrics[\"fix_rounds\"]}\\n文件数：{metrics[\"total_files\"]}\\n测试通过率：{metrics[\"test_pass_rate\"]}'''\n        write_file(f'{self.state.workspace_path}/README.md', report)\n        self.logger.info('项目文档已生成')", "x": 1120, "y": 5640, "width": 450, "height": 200},
		{"id": "deliver_5", "type": "text", "text": "        # 步骤3：交付项目\n        print(f'项目已完成，路径：{self.state.workspace_path}')\n        self.logger.info('交付完成')", "x": 1120, "y": 5860, "width": 450, "height": 100}
