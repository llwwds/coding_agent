# =========================
# macOS 系统垃圾文件排除
# =========================

# General (常规系统文件)
.DS_Store
.AppleDouble
.LSOverride

# Icon must end with two \r (自定义文件夹图标)
Icon

# Thumbnails (缩略图和 AppleDouble 扩展属性文件)
._*

# Files that might appear in the root of a volume (可能出现在磁盘根目录的隐藏文件/文件夹)
.DocumentRevisions-V100
.fseventsd
.Spotlight-V100
.TemporaryItems
.Trashes
.VolumeIcon.icns
.com.apple.timemachine.donotpresent

# Directories potentially created on remote AFP share (在网络共享盘中可能生成的文件夹)
.AppleDB
.AppleDesktop
Network Trash Folder
Temporary Items
.apdisk

# macOS generated files in zip (macOS 压缩包解压时常见的残留文件夹)
__MACOSX/

# Environment & Secrets
.env
.env.local
.env.*.local

# Logs & outputs
workspace/logs/
*.log

# Delivery reports
workspace/DELIVERY_REPORT.json

# Python cache
__pycache__/
*.pyc
*.pyo

# Test / coverage
.cache/
.pytest_cache/
.coverage
htmlcov/